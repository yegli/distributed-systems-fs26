# Copy this file to .env and fill in the values before running docker compose up

# PostgreSQL password (used by both the postgres container and backend DATABASE_URL)
POSTGRES_PASSWORD=changeme

# JWT signing secrets — use long random strings in production
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme
REFRESH_TOKEN_SECRET=changeme2

# Token lifetimes — use ms/jsonwebtoken duration strings (e.g. 15m, 1h, 7d)
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# OpenAI API key — required for the AI trip summary feature (task 05)
# Leave blank to receive a mock summary instead of a real one
OPENAI_API_KEY=
